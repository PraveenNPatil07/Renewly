# Renewly — required environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Backend selection (the dual-prize-track toggle) ────────────────────────
# Set to "local" for local file-based Cognee (open-source prize track)
# Set to "cloud" for Cognee Cloud (cloud prize track)
RENEWLY_BACKEND=local

# ── LLM (for text parsing in ingestion_service) ───────────────────────────
# If absent, the service falls back to regex heuristics — still functional.
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini   # optional, defaults to gpt-4o-mini

# ── Local Cognee (only used when RENEWLY_BACKEND=local) ───────────────────
# Path where Cognee stores its local graph, vectors, and SQLite DB.
# Defaults to ~/.renewly/cognee_data if unset.
COGNEE_DATA_PATH=~/.renewly/cognee_data

# ── Cognee Cloud (only used when RENEWLY_BACKEND=cloud) ───────────────────
# Find these at: https://platform.cognee.ai/api-keys → Connection Details
#
# API Base URL  — the tenant-specific URL shown on the API Keys page
#   e.g. https://tenant-<your-tenant-id>.aws.cognee.ai
COGNEE_CLOUD_URL=https://tenant-<your-tenant-id>.aws.cognee.ai
#
# API Key — create one on the API Keys page ("Create new key" button)
COGNEE_CLOUD_API_KEY=your-cognee-cloud-api-key-here
#
# Tenant ID — shown in the "Tenant ID" box on the API Keys page
COGNEE_CLOUD_TENANT_ID=your-tenant-id-here
#
# User ID — shown in the "User ID" box (optional, used for namespacing)
COGNEE_CLOUD_USER_ID=your-user-id-here
